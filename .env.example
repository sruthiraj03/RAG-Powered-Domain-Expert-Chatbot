OPENAI_API_KEY=your_openai_api_key_here

# You must provide a real name + email for SEC-friendly user-agent usage in the downloader
# Example:
# SEC_DOWNLOADER_NAME=John Smith
# SEC_DOWNLOADER_EMAIL=john@email.com

SEC_DOWNLOADER_NAME=your_name_here
SEC_DOWNLOADER_EMAIL=your_email_here

# Chroma persistence directory
CHROMA_DIR=data/chroma

# Choose your OpenAI models
EMBEDDING_MODEL=text-embedding-3-small
GEN_MODEL=gpt-4o-mini